# Sample variable values for the root module.
# Copy to a real .tfvars file (e.g. terraform.tfvars) and replace placeholders.
# Apply with:  terraform apply -var-file=terraform.tfvars

# Generic
aws_region = "us-east-1"
enabled    = true

# Tags and naming
application_code = "ecc"
application_name = "ecc"
environment_type = "dev"

# Networking
vpc_id                 = "vpc-0123456789abcdef0"
subnet_ids             = ["subnet-aaaaaaaa", "subnet-bbbbbbbb"]
dns_zone_name          = "" # e.g. "sap.internal" — empty skips Route53 records
customer_default_sg_id = [] # e.g. ["sg-0123456789abcdef0"]

# Operating system
ami_id  = "ami-0123456789abcdef0" # SAP-certified SLES/RHEL AMI
ssh_key = ""                      # empty => use SSM Session Manager

# Security
kms_key_arn           = "" # arn:aws:kms:...  (recommended for encryption)
default_instance_role = true

# SAP parameters
sid       = "ECC"
enable_ha = false # set true to provision a second HANA and ASCS instance

# HANA database parameters
hana_is_scale_out               = false
hana_instance_type              = "r5.2xlarge"
root_volume_size                = 50
hana_disks_data_storage_type    = "gp3" # gp3, gp2 or io1
hana_disks_logs_storage_type    = "gp3" # gp3, gp2 or io1
hana_disks_backup_storage_type  = "st1"
hana_disks_shared_storage_type  = "gp3"
hana_disks_shared_size          = "512"
hana_disks_usr_sap_storage_type = "gp3"
hana_disks_usr_sap_storage_size = 50

# NetWeaver application server parameters
ascs_instance_type          = "m5.xlarge"
as_instance_type            = "m5.xlarge"
as_instance_count           = 1
efs_sapmnt                  = true
ascs_root_volume_size       = 50
app_server_root_volume_size = 50
